<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/summaryRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="4">

            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statCollections" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_collections" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statItems" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_items" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statRoots" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_roots" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statTime" style="@style/HomeStatNum" android:text="--" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_updated" />
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/homeFilterChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="6dp"
                app:singleLine="true"
                app:singleSelection="true" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/homePager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/prevPageBtn"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prev_page"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nextPageBtn"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/next_page"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/pageInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="@color/mv_primary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/homePagerActionBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/mv_green"
                android:text="@string/refresh_recommend"
                android:textColor="@color/mv_bg"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:textColor="@color/mv_muted"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/gridRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:padding="6dp" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/no_items"
            android:textColor="@color/mv_muted"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>