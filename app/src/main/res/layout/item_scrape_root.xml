<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/rootTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/mv_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/rootSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/mv_text_secondary"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScrapeRoot"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scrape_root_incremental"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRescrapeRoot"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/scrape_root_rescan"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoveRoot"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/scrape_root_remove"
            android:textColor="@color/mv_amber_on"
            android:backgroundTint="@color/mv_amber"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>