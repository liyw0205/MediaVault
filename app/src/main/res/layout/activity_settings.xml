<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/local_roots_title"
            android:textColor="@color/mv_text"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/localRootsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pickLocalRootBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/add_local_root" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/remote_roots_title"
            android:textColor="@color/mv_text"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addWebDavBtn"
                style="@style/Widget.MediaVault.Button.SettingsTile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/add_webdav_tile"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addFtpBtn"
                style="@style/Widget.MediaVault.Button.SettingsTile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/add_ftp_tile"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addSmbBtn"
                style="@style/Widget.MediaVault.Button.SettingsTile"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/add_smb_tile"
                android:textSize="12sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/remotesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testWebDavBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/test_remote_pick" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/settings_scrape_section"
            android:textColor="@color/mv_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_scrape_mode_local"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/settings_scrape_mode_online_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/scrapeCoverFilesSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_scrape_cover_files" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/scrapeCoverFrameSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_scrape_cover_frame" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/scrapeNfoSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_scrape_nfo" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/scrapeFilenameSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_scrape_filename" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/scrapeSubtitlesSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_scrape_subtitles" />

        <TextView
            android:id="@+id/scrapeThreadsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.slider.Slider
            android:id="@+id/scrapeThreadsSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1"
            android:valueFrom="1"
            android:valueTo="32" />

        <TextView
            android:id="@+id/scrapeRemoteFrameLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <com.google.android.material.slider.Slider
            android:id="@+id/scrapeRemoteFrameSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1"
            android:valueFrom="1"
            android:valueTo="5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveScrapeSettingsBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_save_scrape" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/data_cleanup_title"
            android:textColor="@color/mv_text"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearCoversBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/data_clear_covers" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearScrapeBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/data_clear_scrape" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearRemoteCacheBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/data_clear_remote_stream" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearLibraryBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/data_clear_library" />
    </LinearLayout>
</ScrollView>