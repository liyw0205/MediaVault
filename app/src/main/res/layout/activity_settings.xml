<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="本地媒体根（SAF 目录 URI，一行一个）"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/localRootsEdit"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <Button
            android:id="@+id/pickLocalRootBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_local_root" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="远程配置（JSON 数组）"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="字段: id, type(webdav|ftp|smb), host, port, user, password, basePath, name"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/remotesEdit"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <Button
            android:id="@+id/testWebDavBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试 WebDAV 列出根目录" />

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="保存" />
    </LinearLayout>
</ScrollView>