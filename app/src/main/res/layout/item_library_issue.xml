<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mv_dialog_bg"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/libraryIssueTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/mv_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/libraryIssueMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/mv_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/libraryIssueOpen"
            style="@style/Widget.MediaVault.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/library_issue_open" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/libraryIssueEvidence"
            style="@style/Widget.MediaVault.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/library_issue_evidence" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/libraryIssueRescrape"
            style="@style/Widget.MediaVault.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/library_issue_rescrape" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/libraryIssueRemove"
            style="@style/Widget.MediaVault.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/library_issue_remove"
            android:textColor="@color/mv_danger" />
    </LinearLayout>
</LinearLayout>
