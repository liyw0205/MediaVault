<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_playback"
            android:textColor="@color/mv_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_default_autoplay_hint"
            android:textColor="@color/mv_muted"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/settingsAutoplayGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/settingsAutoplaySequential"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_autoplay_sequential"
                android:textColor="@color/mv_text" />

            <RadioButton
                android:id="@+id/settingsAutoplayRepeatOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_autoplay_repeat_one"
                android:textColor="@color/mv_text" />

            <RadioButton
                android:id="@+id/settingsAutoplayLoop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_autoplay_loop_collection"
                android:textColor="@color/mv_text" />

            <RadioButton
                android:id="@+id/settingsAutoplayOff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_autoplay_off"
                android:textColor="@color/mv_text" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="@color/mv_line" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_storage"
            android:textColor="@color/mv_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settingsDataHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/mv_muted"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settingsOpenDataStorage"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/data_cleanup_title" />
    </LinearLayout>
</ScrollView>