<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mv_dialog_bg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/remoteSourceManagerSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/mv_text"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/remoteSourceRecheckBad"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/remote_source_recheck_bad"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/remoteSourceManagerRecycler"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="10dp" />
</LinearLayout>
