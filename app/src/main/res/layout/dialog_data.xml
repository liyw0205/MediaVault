<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp"
    android:background="@color/mv_dialog_bg">

    <TextView
        android:id="@+id/dataDialogStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/mv_text"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataClearCovers"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/data_clear_covers" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataClearScrape"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/data_clear_scrape" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataClearRemoteStream"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/data_clear_remote_stream" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dataClearLibrary"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/data_clear_library" />
</LinearLayout>