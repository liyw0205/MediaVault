<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/summaryRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="4">

            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statCollections" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_collections" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statItems" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_items" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statRoots" style="@style/HomeStatNum" android:text="0" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_roots" />
            </LinearLayout>
            <LinearLayout style="@style/HomeStatCell">
                <TextView android:id="@+id/statTime" style="@style/HomeStatNum" android:text="--" />
                <TextView style="@style/HomeStatLabel" android:text="@string/stat_updated" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeWorkbenchPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mv_surface"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/homeWorkbenchTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_workbench_title"
                android:textColor="@color/mv_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/homeWorkbenchSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/home_workbench_summary_placeholder"
                android:textColor="@color/mv_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/homeWorkbenchSources"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/home_workbench_sources_placeholder"
                android:textColor="@color/mv_muted"
                android:textSize="12sp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/homePendingIssueChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="4dp"
                app:singleLine="false"
                app:singleSelection="false" />

            <TextView
                android:id="@+id/homePendingIssueEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:text="@string/home_pending_issue_empty"
                android:textColor="@color/mv_muted"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/homeWorkbenchOpenMaintenance"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:minWidth="0dp"
                android:paddingHorizontal="12dp"
                android:text="@string/home_workbench_open_maintenance"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeWorkflowSections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <LinearLayout
                android:id="@+id/continueSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/continueTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:text="@string/home_continue_watching"
                    android:textColor="@color/mv_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/continueRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/home_shelf_height"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="6dp"
                    android:paddingTop="4dp" />

                <TextView
                    android:id="@+id/continueEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:text="@string/home_continue_empty"
                    android:textColor="@color/mv_muted"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/recentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/recentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:text="@string/home_recently_added"
                    android:textColor="@color/mv_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recentRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/home_shelf_height"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="6dp"
                    android:paddingTop="4dp" />

                <TextView
                    android:id="@+id/recentEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:text="@string/home_recent_empty"
                    android:textColor="@color/mv_muted"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/homeLibraryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:text="@string/home_library_section"
            android:textColor="@color/mv_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/homeFilterChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="6dp"
                app:singleLine="true"
                app:singleSelection="true" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/homePager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/prevPageBtn"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/prev_page"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/nextPageBtn"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/next_page"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/pageInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:textColor="@color/mv_primary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/homePagerActionBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/mv_green"
                android:text="@string/refresh_recommend"
                android:textColor="@color/mv_bg"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:textColor="@color/mv_muted"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/gridRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:padding="6dp" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="32dp"
            android:text="@string/no_items"
            android:textColor="@color/mv_muted"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
