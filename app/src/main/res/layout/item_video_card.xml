<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/mv_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/mv_line"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/coverClickArea"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/mv_surface2"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/coverImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/coverPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="▶"
                android:textColor="@color/mv_muted"
                android:textSize="32sp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/resumeProgress"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_gravity="bottom"
                android:visibility="gone"
                app:indicatorColor="@color/mv_primary"
                app:trackColor="#66000000"
                app:trackCornerRadius="0dp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/infoClickArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:paddingHorizontal="10dp"
                android:paddingTop="8dp"
                android:textColor="@color/mv_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/metaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:textColor="@color/mv_text_secondary"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tagsLine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="10dp"
                android:paddingBottom="8dp"
                android:textColor="@color/mv_text_secondary"
                android:textSize="10sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/queueActionBtn"
                style="@style/Widget.MediaVault.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="8dp"
                android:minHeight="36dp"
                android:paddingHorizontal="8dp"
                android:text="@string/watch_queue_add"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
