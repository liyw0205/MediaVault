<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/searchFusionSidebar"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:background="@color/mv_surface"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:minHeight="48dp"
                    android:textColor="@color/mv_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/searchGoBtn"
                    style="@style/Widget.MediaVault.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:minHeight="44dp"
                    android:text="@string/search_go"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clearSearchBtn"
                    style="@style/Widget.MediaVault.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:minHeight="44dp"
                    android:text="@string/clear_search"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/searchProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/searchSortBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:minHeight="44dp"
            android:text="@string/search_sort_default_label"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/searchSourceBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:minHeight="44dp"
            android:text="@string/search_source_default_label"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/searchTypeBtn"
            style="@style/Widget.MediaVault.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:minHeight="44dp"
            android:text="@string/search_type_default_label"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/searchCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/mv_muted"
            android:textSize="13sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/matchedTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:chipSpacingHorizontal="4dp"
            app:chipSpacingVertical="4dp"
            app:singleLine="false" />

        <include layout="@layout/include_list_pager" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchRecycler"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:descendantFocusability="afterDescendants"
        android:nextFocusLeft="@id/searchFusionSidebar"
        android:padding="10dp" />
</LinearLayout>