<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/collectionsFusionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_bg"
    android:orientation="vertical">

    <!-- 剧集/标签/类型 子类置顶一行，与翻页并排，减间距 -->
    <LinearLayout
        android:id="@+id/fusionMetaPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mv_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp">

        <LinearLayout
            android:id="@+id/fusionTagInfoPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:minHeight="@dimen/mv_fusion_btn_min_height">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/collectionsTabLayout"
                style="@style/Widget.MediaVault.TabLayout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/mv_fusion_btn_min_height"
                app:tabGravity="fill"
                app:tabIndicatorFullWidth="false"
                app:tabMinWidth="48dp"
                app:tabMode="fixed"
                app:tabPaddingEnd="4dp"
                app:tabPaddingStart="4dp"
                app:tabTextAppearance="@style/TextAppearance.MediaVault.Land.Tab" />
        </LinearLayout>

        <include layout="@layout/include_list_pager_compact_land" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fusionMediaPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="120dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/collectionsRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:padding="@dimen/mv_fusion_content_pad" />

        <TextView
            android:id="@+id/collectionsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/no_collections"
            android:textColor="@color/mv_text_secondary"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
