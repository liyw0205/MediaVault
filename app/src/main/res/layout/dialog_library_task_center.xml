<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mv_dialog_bg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/taskCenterSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:text="@string/task_center_summary_empty"
        android:textColor="@color/mv_text"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/taskCenterFilter"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/taskCenterClearFinished"
        style="@style/Widget.MediaVault.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:minWidth="0dp"
        android:text="@string/task_center_clear_finished"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/taskCenterRecycler"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/taskCenterEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:text="@string/task_center_empty"
        android:textColor="@color/mv_muted"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
