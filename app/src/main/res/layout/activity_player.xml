<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mv_player_canvas">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:show_buffering="when_playing"
        app:surface_type="texture_view"
        app:use_controller="false" />

    <LinearLayout
        android:id="@+id/playerTopChrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@color/mv_player_scrim"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/playerTitleGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/playerTitleOverlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/mv_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/playerSessionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/mv_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAudio"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/audio_pick"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            app:tint="@color/mv_text" />

        <ImageButton
            android:id="@+id/btnSubtitle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/subtitle_pick"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/mv_text" />

        <ImageButton
            android:id="@+id/btnScreenshot"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/player_screenshot"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@color/mv_text" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/mv_text" />
    </LinearLayout>

    <TextView
        android:id="@+id/playerSeekCenterOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/mv_player_scrim_mid"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:textColor="@color/mv_text"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/playerBottomChrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/playerProgressExpanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mv_player_scrim"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/playerTimeCurrent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="44dp"
                android:text="0:00"
                android:textColor="@color/mv_text"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/playerSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:max="1000"
                android:progressTint="@color/mv_primary"
                android:thumbTint="@color/mv_primary" />

            <TextView
                android:id="@+id/playerTimeTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="44dp"
                android:gravity="end"
                android:text="0:00"
                android:textColor="@color/mv_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/playerButtonRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mv_player_scrim"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp">

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_prev"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/mv_text" />

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_rewind"
                android:src="@android:drawable/ic_media_rew"
                app:tint="@color/mv_text" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_pause"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/mv_primary" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_forward"
                android:src="@android:drawable/ic_media_ff"
                app:tint="@color/mv_text" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_next"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/mv_text" />

            <ImageButton
                android:id="@+id/btnPlaylist"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_playlist"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/mv_text" />
        </LinearLayout>
    </LinearLayout>

    <SeekBar
        android:id="@+id/playerSeekBarImmersive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent"
        android:max="1000"
        android:minHeight="20dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:progressDrawable="@drawable/player_seek_immersive"
        android:thumb="@null"
        android:visibility="visible" />
</FrameLayout>
