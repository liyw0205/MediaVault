<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scrape_roots_manage_hint"
        android:textAppearance="@style/TextAppearance.MediaVault.Settings.Hint" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/local_roots_title"
        android:textAppearance="@style/TextAppearance.MediaVault.Settings.Section" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drawerLocalRootsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/drawerPickLocalRootBtn"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/add_local_root"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/remote_roots_title"
        android:textAppearance="@style/TextAppearance.MediaVault.Settings.Section" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawerAddWebDavBtn"
            style="@style/Widget.MediaVault.Button.SettingsTile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/add_webdav_tile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawerAddFtpBtn"
            style="@style/Widget.MediaVault.Button.SettingsTile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:text="@string/add_ftp_tile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/drawerAddSmbBtn"
            style="@style/Widget.MediaVault.Button.SettingsTile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/add_smb_tile" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/drawerRemotesList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/drawerTestRemoteBtn"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/test_remote_pick"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/drawerSaveRemotesBtn"
        style="@style/Widget.MediaVault.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/save"
        android:textSize="14sp" />
</LinearLayout>